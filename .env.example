# ============================================================
SLACK_REVIEW_CHANNEL=#legal-ndas


# Slack Bot Token (required for Slack intake / Socket Mode)
# Add scopes: files:read, channels:history, im:history
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # For Socket Mode


# ------------------------------------------------------------
# Email — IMAP intake (Gmail or Outlook)
# For Gmail: enable App Passwords at myaccount.google.com/security
# ------------------------------------------------------------
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=legal@yourcompany.com
EMAIL_PASSWORD=your-app-password
EMAIL_INBOX_FOLDER=INBOX
EMAIL_MNDA_SUBJECT_KEYWORD=NDA        # Trigger on emails containing this word


# SMTP — send review replies
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=legal@yourcompany.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="Legal Operations"


# ------------------------------------------------------------
# Google Drive — Store reviewed MNDAs
# Service account JSON path (download from Google Cloud Console)
# ------------------------------------------------------------
# Set to true to enable: creates a Drive folder after every review
# Folder: "MNDA - {Counterparty Name} - {Date}" | Redlines: "{Counterparty} - MNDA Redlines - {Date}.txt"
GOOGLE_DRIVE_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google_service_account.json
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-folder-id-here   # Root folder for all MNDAs


# ------------------------------------------------------------
# Local Storage (fallback if Google Drive is not configured)
# ------------------------------------------------------------
LOCAL_STORAGE_PATH=./reviews


# ------------------------------------------------------------
# Automation settings
# ------------------------------------------------------------
EMAIL_POLL_INTERVAL_SECONDS=60    # How often to check email
REVIEW_MODE=both                  # claude | keywords | both
LOG_LEVEL=INFO

